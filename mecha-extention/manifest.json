{
  "manifest_version": 3,
  "name": "Mecha Forms Filler",
  "version": "1.2",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mechaforms-api.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}