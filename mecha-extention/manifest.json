{
  "manifest_version": 3,
  "name": "Mecha Forms Filler",
  "version": "1.3",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://mechaforms-api.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/icon.png"
  },
  "icons": {
    "128": "assets/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}